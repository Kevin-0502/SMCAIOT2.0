<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutErrorState"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:visibility="gone"
    android:background="#FFFFFF">

    <!-- Círculo con ícono -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="center">

        <View
            android:id="@+id/viewErrorCircle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_pink" />

        <ImageView
            android:id="@+id/ivErrorIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_no_wifi"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/tvErrorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sin conexión"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="24dp"
        android:textAlignment="center" />

    <!-- Descripción -->
    <TextView
        android:id="@+id/tvErrorDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No fue posible conectar con el servidor.\nRevisa tu internet e inténtalo de nuevo"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="8dp"
        android:textAlignment="center"
        android:lineSpacingMultiplier="1.3" />

    <!-- Botón principal -->
    <TextView
        android:id="@+id/btnErrorAction"
        android:layout_width="200dp"
        android:layout_height="44dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_button_primary"
        android:gravity="center"
        android:text="Reintentar"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Link secundario (opcional) -->
    <TextView
        android:id="@+id/tvErrorSecondaryAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Ir al inicio"
        android:textSize="14sp"
        android:textColor="#555555"
        android:visibility="gone" />

</LinearLayout>
